<%- layout('../layouts/boilerplate') %>

<main class="container py-5">
  <%- include('../../partials/flash') %>

  <a href="/empresas" class="btn btn-outline-secondary btn-sm mb-3">
    <i class="bi bi-arrow-left me-1"></i>Voltar para empresas
  </a>

  <div class="row">
    <div class="col-12 col-lg-8">
      <div class="d-flex align-items-center mb-4">
        <div class="bg-light d-flex align-items-center justify-content-center rounded me-3" style="width: 80px; height: 80px;">
          <i class="bi bi-building" style="font-size: 36px; color: #6c757d"></i>
        </div>
        <div>
          <h1 class="mb-1"><%= company.name %></h1>
          <% if (company.location) { %>
          <p class="text-muted mb-0">
            <i class="bi bi-geo-alt me-1"></i>
            <%= company.location.city %><% if (company.location.state) { %>, <%= formatState(company.location.state, 1) %><% } %>
            <% if (company.location.country && company.location.country !== 'Brasil') { %> - <%= company.location.country %><% } %>
          </p>
          <% } %>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3">Sobre a empresa</h5>
          <p class="card-text" style="white-space: pre-line;"><%= company.description || 'Sem descrição.' %></p>
        </div>
      </div>

      <div class="d-flex flex-wrap gap-3 mb-4">
        <% if (company.phone) { %>
        <span class="badge bg-secondary fs-6">
          <i class="bi bi-telephone me-1"></i><%= company.phone %>
        </span>
        <% } %>
        <span class="badge bg-primary fs-6">
          <i class="bi bi-briefcase me-1"></i><%= jobs.length %> vaga(s) publicada(s)
        </span>
        <span class="text-muted">
          <i class="bi bi-clock me-1"></i>Membro desde <%= company.createdAt ? new Date(company.createdAt).toLocaleDateString('pt-BR') : '' %>
        </span>
      </div>

      <hr>

      <h3 class="mb-3">Vagas desta empresa</h3>

      <% if (jobs.length === 0) { %>
        <div class="alert alert-info">Esta empresa ainda não publicou vagas.</div>
      <% } else { %>
        <div class="row row-cols-1 row-cols-md-2 g-3">
          <% jobs.forEach((job) => { %>
          <div class="col">
            <div class="card h-100 shadow-sm">
              <div class="card-body d-flex flex-column">
                <h5 class="card-title mb-1"><%= truncateToLastWord(job.title || '', 50) %></h5>
                <p class="card-text text-muted mb-2" style="max-height: 3.6em; overflow: hidden;">
                  <%= job.description ? truncateToLastWord(job.description, 100) : 'Sem descrição.' %>
                </p>
                <div class="mt-auto">
                  <div class="d-flex flex-wrap gap-2 mb-2">
                    <% if (job.salary) { %>
                      <span class="badge bg-info text-dark">R$ <%= job.salary.toLocaleString('pt-BR') %></span>
                    <% } %>
                    <span class="badge bg-secondary"><%= job.type %></span>
                    <% if (job.isRemote) { %>
                      <span class="badge bg-success">Remoto</span>
                    <% } %>
                  </div>
                  <a href="/vagas/<%= job._id %>" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-briefcase me-1"></i>Ver vaga
                  </a>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</main>
