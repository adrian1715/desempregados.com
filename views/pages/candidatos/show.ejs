<%- layout('../layouts/boilerplate') %>

<main class="container py-5">
  <%- include('../../partials/flash') %>

  <a href="/candidatos" class="btn btn-outline-secondary btn-sm mb-3">
    <i class="bi bi-arrow-left me-1"></i>Voltar para candidatos
  </a>

  <div class="row">
    <div class="col-12 col-lg-8">
      <div class="d-flex align-items-center mb-4">
        <div class="bg-light d-flex align-items-center justify-content-center rounded-circle me-3" style="width: 80px; height: 80px;">
          <i class="bi bi-person-fill" style="font-size: 36px; color: #6c757d"></i>
        </div>
        <div>
          <h1 class="mb-1"><%= candidate.name.first %> <%= candidate.name.last %></h1>
          <p class="text-muted mb-0">
            <i class="bi bi-geo-alt me-1"></i>
            <%= candidate.location.city %><% if (candidate.location.state) { %>, <%= formatState(candidate.location.state, 1) %><% } %>
          </p>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3">Informações de contato</h5>
          <% if (currentUser) { %>
            <div class="d-flex flex-wrap gap-3">
              <span class="badge bg-secondary fs-6">
                <i class="bi bi-telephone me-1"></i><%= candidate.phone %>
              </span>
              <% if (email) { %>
              <span class="badge bg-success fs-6">
                <i class="bi bi-envelope-at me-1"></i><%= email %>
              </span>
              <% } %>
            </div>
          <% } else { %>
            <p class="text-muted">
              <i class="bi bi-lock me-1"></i>Faça <a href="/login">login</a> para ver as informações de contato.
            </p>
          <% } %>
        </div>
      </div>

      <div class="d-flex flex-wrap gap-3 mb-4">
        <span class="badge bg-primary fs-6">
          <i class="bi bi-file-earmark-person me-1"></i><%= candidate.appliedJobs ? candidate.appliedJobs.length : 0 %> candidatura(s)
        </span>
        <span class="text-muted">
          <i class="bi bi-clock me-1"></i>Membro desde <%= candidate.createdAt ? new Date(candidate.createdAt).toLocaleDateString('pt-BR') : '' %>
        </span>
      </div>

      <% if (candidate.appliedJobs && candidate.appliedJobs.length > 0) { %>
      <hr>
      <h3 class="mb-3">Vagas aplicadas</h3>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        <% candidate.appliedJobs.forEach((job) => { %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title mb-1"><%= truncateToLastWord(job.title || '', 50) %></h5>
              <% if (job.company) { %>
              <h6 class="card-subtitle text-muted mb-2"><%= job.company.name %></h6>
              <% } %>
              <div class="mt-auto">
                <a href="/vagas/<%= job._id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-briefcase me-1"></i>Ver vaga
                </a>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</main>
