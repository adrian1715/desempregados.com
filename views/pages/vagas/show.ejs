<%- layout('../layouts/boilerplate') %>

<main class="container py-5">
  <%- include('../../partials/flash') %>

  <div class="row">
    <div class="col-12 col-lg-8">
      <a href="/vagas" class="btn btn-outline-secondary btn-sm mb-3">
        <i class="bi bi-arrow-left me-1"></i>Voltar para vagas
      </a>

      <h1 class="mb-2"><%= job.title %></h1>

      <div class="d-flex flex-wrap gap-2 mb-4">
        <% if (job.salary) { %>
          <span class="badge bg-info text-dark fs-6">
            <i class="bi bi-cash me-1"></i>R$ <%= job.salary.toLocaleString('pt-BR') %>
          </span>
        <% } else { %>
          <span class="badge bg-secondary fs-6">Salário não informado</span>
        <% } %>

        <span class="badge bg-secondary fs-6">
          <i class="bi bi-calendar-event me-1"></i><%= job.type %>
        </span>

        <% if (job.isRemote) { %>
          <span class="badge bg-success fs-6">
            <i class="bi bi-house-door me-1"></i>Remoto
          </span>
        <% } %>

        <% if (job.location) { %>
          <span class="badge bg-info text-dark fs-6">
            <i class="bi bi-geo-alt me-1"></i><%= job.location %>
          </span>
        <% } %>

        <span class="badge bg-primary fs-6">
          <i class="bi bi-people me-1"></i><%= job.appliedCandidates ? job.appliedCandidates.length : 0 %> candidato(s)
        </span>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3">Descrição da vaga</h5>
          <p class="card-text" style="white-space: pre-line;"><%= job.description %></p>
        </div>
      </div>

      <% if (job.position) { %>
      <div class="mb-4">
        <span class="text-muted">Carreira / Posição:</span>
        <a href="/carreiras/<%= job.position.name ? job.position.name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '') : '' %>" class="ms-1">
          <%= job.position.name %>
        </a>
      </div>
      <% } %>

      <p class="text-muted">
        <i class="bi bi-clock me-1"></i>Publicada em <%= job.createdAt ? new Date(job.createdAt).toLocaleDateString('pt-BR') : 'data desconhecida' %>
      </p>

      <hr>

      <div class="d-flex gap-2 flex-wrap">
        <% if (currentUser && currentUser.role === 'candidate') { %>
          <% if (hasApplied) { %>
            <form action="/api/jobs/<%= job._id %>/unapply" method="POST">
              <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-x-circle me-1"></i>Cancelar candidatura
              </button>
            </form>
          <% } else { %>
            <form action="/api/jobs/<%= job._id %>/apply" method="POST">
              <button type="submit" class="btn btn-success btn-lg">
                <i class="bi bi-send me-1"></i>Candidatar-se
              </button>
            </form>
          <% } %>
        <% } else if (!currentUser) { %>
          <a href="/login" class="btn btn-success btn-lg">
            <i class="bi bi-send me-1"></i>Faça login para se candidatar
          </a>
        <% } %>
      </div>
    </div>

    <div class="col-12 col-lg-4 mt-4 mt-lg-0">
      <% if (job.company) { %>
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <div class="bg-light d-flex align-items-center justify-content-center rounded mb-3" style="height: 80px">
            <i class="bi bi-building" style="font-size: 36px; color: #6c757d"></i>
          </div>
          <h5 class="card-title"><%= job.company.name %></h5>
          <p class="card-text text-muted" style="max-height: 4.5em; overflow: hidden;">
            <%= job.company.description ? truncateToLastWord(job.company.description, 120) : 'Sem descrição.' %>
          </p>

          <% if (job.company.location) { %>
          <p class="text-muted mb-2">
            <i class="bi bi-geo-alt me-1"></i>
            <%= job.company.location.city %><% if (job.company.location.state) { %>, <%= formatState(job.company.location.state, 1) %><% } %>
          </p>
          <% } %>

          <a href="/empresas/<%= job.company._id %>" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-buildings me-1"></i>Ver empresa
          </a>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</main>
